{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@shared/*": ["../../packages/shared/src/*"],
      "@clinicall/shared": ["../../packages/shared/src"],
      "@clinicall/shared/*": ["../../packages/shared/src/*"]
    },
    "types": ["react", "react-native"]
  },
  "include": ["**/*.ts", "**/*.tsx", "expo-env.d.ts"],
  "exclude": ["node_modules", "android", "ios"]
}
